{
  "name": "Dropbox Sync",
  "version": "2.0.0",
  "slug": "dropbox_sync",
  "description": "Upload your Home Assistant backups to Dropbox",
  "url": "https://github.com/danielwelch/hassio-dropbox-sync",
  "startup": "before",
  "arch": [
    "aarch64",
    "amd64",
    "armhf",
    "armv7",
    "i386"
  ],
  "stdin": true,
  "hassio_api": true,
  "hassio_role": "manager",
  "boot": "auto",
  "map": ["backup", "share"],
  "options": {
    "app_key": "",
    "app_secret": "",
    "refresh_token": "",
    "output": ""
  },
  "schema": {
    "app_key": "str",
    "app_secret": "str",
    "refresh_token": "str",
    "output": "str",
    "keep_last": "int(0,)?",
    "filetypes": "str?"
  }
}
